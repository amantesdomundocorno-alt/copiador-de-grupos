# ===================================================
# COPIADOR INDEXADOR - CONFIGURAÇÃO DE AMBIENTE
# ===================================================
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env para repositórios git!
# ===================================================

# --- Credenciais Telegram (Opcional) ---
# Se definidas aqui, serão usadas como padrão para novas contas
# Obtenha em: https://my.telegram.org/apps

# TELEGRAM_API_ID=12345678
# TELEGRAM_API_HASH=abcdef0123456789abcdef0123456789

# --- Configurações de Proxy (Opcional) ---
# Formato SOCKS5: socks5://usuario:senha@host:porta
# Formato HTTP: http://usuario:senha@host:porta

# PROXY_URL=socks5://127.0.0.1:1080

# --- Configurações de Performance ---
# MAX_RETRIES=5
# CONNECTION_TIMEOUT=60
# READ_TIMEOUT=120

# --- Configurações de Backup ---
# BACKUP_DIR=dados/backups
# MAX_BACKUPS=7

# --- Configurações de Log ---
# LOG_LEVEL=INFO
# LOG_DIR=dados/logs
